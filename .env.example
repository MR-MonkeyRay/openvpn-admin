APP_PORT=3000
APP_BASE_URL=https://vpn-admin.example.com
PORT=3000
NODE_ENV=production

SESSION_SECRET=change-me-with-32-plus-random-bytes
CSRF_SECRET=change-me-with-32-plus-random-bytes
SESSION_COOKIE_NAME=openvpn_admin.sid
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=change-me-now
TRUST_PROXY=1

OVPN_INSTANCE_NAME=server
OVPN_PORT=1194
OVPN_PROTO=udp
OVPN_PUBLIC_HOST=vpn.example.com
OVPN_AUTO_INIT=true
OVPN_SERVER_NETWORK=10.8.0.0 255.255.255.0
OVPN_SERVER_CONF_PATH=/mnt/openvpn/server/server.conf
OVPN_AUTH_SCRIPT_PATH=/mnt/openvpn/scripts/auth_verify
OVPN_MGMT_SOCKET=/mnt/openvpn/run/server-management.sock
OVPN_STATUS_PATH=/mnt/openvpn/server/openvpn-status.log
OVPN_LOG_PATH=/mnt/openvpn/server/openvpn.log
BACKUP_RETENTION_COUNT=10

APP_OPENVPN_SERVER_DIR=/mnt/openvpn/server
APP_OPENVPN_SCRIPTS_DIR=/mnt/openvpn/scripts
APP_OPENVPN_RUN_DIR=/mnt/openvpn/run
APP_WRAPPER_PATH=/usr/local/bin/openvpn-admin-wrapper

# Legacy host-mode only
HOST_OPENVPN_SERVER_DIR=/etc/openvpn/server
HOST_OPENVPN_SCRIPTS_DIR=/etc/openvpn/scripts
HOST_OPENVPN_RUN_DIR=/run/openvpn
HOST_APP_DATA_DIR=/var/lib/openvpn-admin
HOST_APP_LOG_DIR=/var/log/openvpn-admin
HOST_WRAPPER_PATH=/usr/local/bin/openvpn-admin-wrapper

# Production hardening checklist
# - APP_BASE_URL must use https in production
# - SESSION_SECRET / CSRF_SECRET must be long random values
# - INIT_ADMIN_PASSWORD must be rotated before exposure
# - TRUST_PROXY must match your reverse proxy hops (for example 1)
